{
  "name": "s3man",
  "private": true,
  "version": "0.1.1",
  "description": "Cross-platform S3 desktop manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarrietav-dev/s3man.git"
  },
  "homepage": "https://github.com/sarrietav-dev/s3man",
  "bugs": {
    "url": "https://github.com/sarrietav-dev/s3man/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dist": "tauri build",
    "dist:linux": "tauri build --bundles deb,rpm",
    "dist:linux:all": "tauri build --bundles appimage,deb,rpm",
    "dist:mac": "tauri build --bundles app,dmg",
    "dist:windows": "tauri build --bundles msi,nsis",
    "dist:aur": "bash scripts/release/generate-aur.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@tailwindcss/vite": "^4.2.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next-themes": "^0.4.6",
    "react": "^19.1.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.7.2",
    "recharts": "^2.15.4",
    "shadcn": "^4.0.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/node": "^25.4.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
