pkgbase = s3man-bin
	pkgdesc = Cross-platform S3 desktop manager
	pkgver = 0.1.0
	pkgrel = 1
	url = https://github.com/sarrietav-dev/s3man
	install = s3man.install
	arch = x86_64
	arch = aarch64
	license = MIT
	depends = cairo
	depends = desktop-file-utils
	depends = gdk-pixbuf2
	depends = glib2
	depends = gtk3
	depends = hicolor-icon-theme
	depends = libsoup
	depends = pango
	depends = webkit2gtk-4.1
	options = !strip
	options = !emptydirs
	source_x86_64 = https://github.com/sarrietav-dev/s3man/releases/download/v0.1.0/s3man_0.1.0_amd64.deb
	sha256sums_x86_64 = REPLACE_WITH_AMD64_SHA256
	source_aarch64 = https://github.com/sarrietav-dev/s3man/releases/download/v0.1.0/s3man_0.1.0_arm64.deb
	sha256sums_aarch64 = REPLACE_WITH_ARM64_SHA256

pkgname = s3man-bin
