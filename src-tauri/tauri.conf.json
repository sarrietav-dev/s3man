{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "s3man",
  "version": "0.1.0",
  "identifier": "com.sebas.s3man",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "app",
      "dmg",
      "appimage",
      "deb",
      "rpm"
    ],
    "category": "Utility",
    "shortDescription": "Cross-platform S3 desktop manager",
    "copyright": "Copyright (c) 2026",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "hardenedRuntime": true
    },
    "linux": {
      "deb": {
        "section": "utils",
        "priority": "optional",
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0"
        ]
      },
      "rpm": {
        "epoch": 0,
        "release": "1",
        "depends": [
          "webkit2gtk4.1",
          "gtk3"
        ]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}
